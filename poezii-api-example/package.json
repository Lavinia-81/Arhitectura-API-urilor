{
  "name": "poezii-api",
  "version": "1.0.0",
  "type": "module",
  "description": "API cultural pentru literatura română - poezii, autori, texte integrale",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --watch src --exec \"npm run build && node dist/index.js\"",
    "build": "tsc",
    "start": "node dist/index.js",
    "seed": "node dist/prisma/seed.js",
    "migrate": "prisma migrate deploy",
    "migrate:dev": "prisma migrate dev",
    "studio": "prisma studio",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "clean": "rm -rf dist",
    "prebuild": "npm run clean",
    "postinstall": "prisma generate"
  },
  "keywords": [
    "api",
    "poetry",
    "romanian-literature",
    "fastify",
    "prisma",
    "typescript"
  ],
  "author": "Echipa Poezii API",
  "license": "MIT",
  "dependencies": {
    "@fastify/cors": "^9.0.0",
    "@fastify/helmet": "^11.0.0",
    "@fastify/rate-limit": "^9.0.0",
    "@fastify/swagger": "^8.15.0",
    "@fastify/swagger-ui": "^1.10.2",
    "@prisma/client": "^5.0.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.0.0",
    "fastify": "^4.0.0",
    "ioredis": "^5.0.0",
    "jsonwebtoken": "^9.0.0",
    "pino": "^8.0.0",
    "pino-pretty": "^10.0.0",
    "prom-client": "^15.1.3",
    "redis": "^6.0.1",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^29.0.0",
    "@types/node": "^20.19.43",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.0.0",
    "nodemon": "^3.0.0",
    "prettier": "^3.0.0",
    "prisma": "^5.0.0",
    "ts-jest": "^29.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
