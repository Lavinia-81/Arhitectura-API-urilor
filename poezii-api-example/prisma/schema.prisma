// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Plan {
  FREE
  PRO
  ENTERPRISE
}

enum PoemType {
  EPIC
  LYRIC
  DRAMATIC
  EPISTOLARY
}

// ====================================================
// Model: Author (Poetul)
// ====================================================

model Author {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  slug      String   @unique
  bio       String?
  birthYear Int?
  deathYear Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relatii
  poems Poem[]
}

// ======================================================
// Model: Poem (Poezia)
// ======================================================

model Poem {
  id          Int       @id @default(autoincrement())
  title       String
  slug        String    @unique
  fullText     String?   // text integral
  summary     String?   // rezumat sau primele versuri
  year        Int?
  type        PoemType  @default(LYRIC)
  keywords    String?   // cuvinte cheie separate prin virgulă
  popularity  Int       @default(0)
  authorId    Int
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  author Author @relation(fields: [authorId], references: [id])
}

// ==========================================================
// Model: ApiKey (Acces si planuri)
// ==========================================================

model ApiKey {
  id        String   @id @default(cuid())
  prefix    String   // de ex. "poezii_test"
  keyHash   String   @unique // hash-ul cheii reale
  plan      Plan     @default(FREE)
  createdAt DateTime @default(now())
  expiresAt DateTime?
  lastUsed  DateTime?

  usageLogs UsageLog[]
}

// =========================================================
// Model: UsageLog (Monitorizare)
// =========================================================

model UsageLog {
  id        String   @id @default(cuid())
  apiKeyId  String
  endpoint  String
  method    String
  status    Int
  ipHash    String   // hash-ul IP-ului pentru confidențialitate (GDPR friendly)
  createdAt DateTime @default(now())

  apiKey ApiKey @relation(fields: [apiKeyId], references: [id])
}
